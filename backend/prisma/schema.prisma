generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  CASHIER
  STAFF
}

enum ApprovalStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  ACTIVE
  DISCONTINUED
  OUT_OF_STOCK
}

enum InvoiceStatus {
  DRAFT
  PAID
  PENDING
  PARTIALLY_PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  CREDIT
}

enum PaymentStatus {
  PAID
  PENDING
  PARTIALLY_PAID
  CANCELLED
}

enum InventoryLogType {
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
  DAMAGED
  EXPIRED
  LOST
  RETURN
  SALE
  OPENING
}

enum AuditAction {
  LOGIN
  LOGOUT
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  PAYMENT
  STOCK_IN
  STOCK_OUT
  EXPORT
  IMPORT
  SETTINGS_CHANGE
}

enum NotificationType {
  LOW_STOCK
  OUT_OF_STOCK
  PRODUCT_PENDING_APPROVAL
  PRODUCT_APPROVED
  PRODUCT_REJECTED
  CREDIT_DUE
  NEAR_EXPIRY
  EXPIRED_STOCK
  INVOICE_CREATED
  PAYMENT_RECEIVED
  SYSTEM
}

// ─────────────────────────────────────────────
// COMPANY
// ─────────────────────────────────────────────

model Company {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  email       String   @unique
  phone       String?
  address     String?
  city        String?
  country     String   @default("US")
  logoUrl     String?
  website     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  settings     CompanySettings?
  users        User[]
  categories   Category[]
  suppliers    Supplier[]
  products     Product[]
  customers    Customer[]
  invoices     Invoice[]
  inventory    InventoryLog[]
  adjustments  StockAdjustment[]
  auditLogs    AuditLog[]
  notifications Notification[]
  heldInvoices HeldInvoice[]

  @@map("companies")
}

model CompanySettings {
  id                  String   @id @default(cuid())
  companyId           String   @unique
  currency            String   @default("USD")
  currencySymbol      String   @default("$")
  taxEnabled          Boolean  @default(false)
  taxRate             Decimal  @default(0) @db.Decimal(5, 2)
  taxLabel            String   @default("Tax")
  invoicePrefix       String   @default("INV")
  invoiceCounter      Int      @default(1)
  lowStockThreshold   Int      @default(10)
  requireApproval     Boolean  @default(true)
  allowStaffDiscount  Boolean  @default(true)
  receiptFooter       String?
  timezone            String   @default("UTC")
  dateFormat          String   @default("MM/DD/YYYY")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_settings")
}

// ─────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  companyId    String
  email        String
  password     String
  firstName    String
  lastName     String
  phone        String?
  role         UserRole  @default(CASHIER)
  isActive     Boolean   @default(true)
  avatarUrl    String?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  company           Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  permissions       UserPermission[]
  refreshTokens     RefreshToken[]
  createdProducts   Product[]           @relation("ProductCreatedBy")
  approvedProducts  Product[]           @relation("ProductApprovedBy")
  approvalLogs      ProductApprovalLog[]
  invoices          Invoice[]
  adjustments       StockAdjustment[]
  auditLogs         AuditLog[]
  notifications     Notification[]

  @@unique([companyId, email])
  @@map("users")
}

model UserPermission {
  id         String   @id @default(cuid())
  userId     String
  permission String
  granted    Boolean  @default(true)
  createdAt  DateTime @default(now())

  user  User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permission])
  @@map("user_permissions")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  user  User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// CATALOG
// ─────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?
  color       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([companyId, name])
  @@map("categories")
}

model Supplier {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  city        String?
  country     String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products  Product[]

  @@map("suppliers")
}

model Product {
  id                   String         @id @default(cuid())
  companyId            String
  categoryId           String?
  supplierId           String?
  createdById          String
  approvedById         String?

  name                 String
  sku                  String
  barcode              String?
  brand                String?
  description          String?
  unit                 String         @default("pcs")

  costPrice            Decimal        @db.Decimal(12, 2)
  sellingPrice         Decimal        @db.Decimal(12, 2)

  discountEnabled      Boolean        @default(false)
  maxDiscountPercent   Decimal        @default(0) @db.Decimal(5, 2)
  maxDiscountAmount    Decimal        @default(0) @db.Decimal(12, 2)

  currentStock         Int            @default(0)
  openingStock         Int            @default(0)
  reorderLevel         Int            @default(0)
  lowStockThreshold    Int            @default(5)

  shelfNumber          String?
  shelfRow             String?
  rackNumber           String?

  expiryDate           DateTime?
  batchNumber          String?

  approvalStatus       ApprovalStatus @default(PENDING_APPROVAL)
  approvedAt           DateTime?
  rejectionReason      String?
  isActive             Boolean        @default(true)

  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  company           Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category          Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  supplier          Supplier?            @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  createdBy         User                 @relation("ProductCreatedBy", fields: [createdById], references: [id])
  approvedBy        User?                @relation("ProductApprovedBy", fields: [approvedById], references: [id])
  approvalLogs      ProductApprovalLog[]
  invoiceItems      InvoiceItem[]
  inventoryLogs     InventoryLog[]

  @@unique([companyId, sku])
  @@map("products")
}

model ProductApprovalLog {
  id          String         @id @default(cuid())
  productId   String
  reviewedById String
  action      ApprovalStatus
  reason      String?
  createdAt   DateTime       @default(now())

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  reviewedBy  User     @relation(fields: [reviewedById], references: [id])

  @@map("product_approval_logs")
}

// ─────────────────────────────────────────────
// CUSTOMERS
// ─────────────────────────────────────────────

model Customer {
  id              String   @id @default(cuid())
  companyId       String
  name            String
  email           String?
  phone           String?
  address         String?
  creditLimit     Decimal  @default(0) @db.Decimal(12, 2)
  creditBalance   Decimal  @default(0) @db.Decimal(12, 2)
  notes           String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company              Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices             Invoice[]
  creditTransactions   CustomerCreditTransaction[]

  @@map("customers")
}

// ─────────────────────────────────────────────
// INVOICES & PAYMENTS
// ─────────────────────────────────────────────

model Invoice {
  id              String        @id @default(cuid())
  companyId       String
  customerId      String?
  createdById     String
  invoiceNumber   String

  subtotal        Decimal       @db.Decimal(12, 2)
  discountAmount  Decimal       @default(0) @db.Decimal(12, 2)
  taxAmount       Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal       @db.Decimal(12, 2)
  paidAmount      Decimal       @default(0) @db.Decimal(12, 2)
  balanceAmount   Decimal       @default(0) @db.Decimal(12, 2)

  paymentMethod   PaymentMethod @default(CASH)
  status          InvoiceStatus @default(PAID)
  notes           String?

  cashReceived    Decimal?      @db.Decimal(12, 2)
  changeGiven     Decimal?      @db.Decimal(12, 2)

  profit          Decimal       @default(0) @db.Decimal(12, 2)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer  Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdBy User          @relation(fields: [createdById], references: [id])
  items     InvoiceItem[]
  payments  Payment[]

  @@unique([companyId, invoiceNumber])
  @@map("invoices")
}

model InvoiceItem {
  id              String   @id @default(cuid())
  invoiceId       String
  productId       String
  productName     String
  sku             String
  quantity        Int
  unit            String
  costPrice       Decimal  @db.Decimal(12, 2)
  sellingPrice    Decimal  @db.Decimal(12, 2)
  discountPercent Decimal  @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal  @default(0) @db.Decimal(12, 2)
  taxAmount       Decimal  @default(0) @db.Decimal(12, 2)
  lineTotal       Decimal  @db.Decimal(12, 2)
  profit          Decimal  @db.Decimal(12, 2)
  createdAt       DateTime @default(now())

  invoice  Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@map("invoice_items")
}

model Payment {
  id            String        @id @default(cuid())
  invoiceId     String
  amount        Decimal       @db.Decimal(12, 2)
  method        PaymentMethod
  status        PaymentStatus @default(PAID)
  reference     String?
  notes         String?
  createdAt     DateTime      @default(now())

  invoice  Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model CustomerCreditTransaction {
  id          String   @id @default(cuid())
  customerId  String
  invoiceId   String?
  type        String
  amount      Decimal  @db.Decimal(12, 2)
  balanceBefore Decimal @db.Decimal(12, 2)
  balanceAfter  Decimal @db.Decimal(12, 2)
  notes       String?
  createdAt   DateTime @default(now())

  customer  Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_credit_transactions")
}

// ─────────────────────────────────────────────
// HELD INVOICES (Park & Resume)
// ─────────────────────────────────────────────

model HeldInvoice {
  id          String   @id @default(cuid())
  companyId   String
  createdById String
  label       String?
  cartData    Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("held_invoices")
}

// ─────────────────────────────────────────────
// INVENTORY
// ─────────────────────────────────────────────

model InventoryLog {
  id           String           @id @default(cuid())
  companyId    String
  productId    String
  type         InventoryLogType
  quantity     Int
  quantityBefore Int
  quantityAfter  Int
  reference    String?
  notes        String?
  createdById  String?
  createdAt    DateTime         @default(now())

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@map("inventory_logs")
}

model StockAdjustment {
  id           String           @id @default(cuid())
  companyId    String
  productId    String
  type         InventoryLogType
  quantity     Int
  reason       String?
  notes        String?
  adjustedById String
  createdAt    DateTime         @default(now())

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  adjustedBy  User     @relation(fields: [adjustedById], references: [id])

  @@map("stock_adjustments")
}

// ─────────────────────────────────────────────
// AUDIT & NOTIFICATIONS
// ─────────────────────────────────────────────

model AuditLog {
  id          String      @id @default(cuid())
  companyId   String
  userId      String?
  action      AuditAction
  entity      String
  entityId    String?
  description String
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model Notification {
  id          String           @id @default(cuid())
  companyId   String
  userId      String?
  type        NotificationType
  title       String
  message     String
  data        Json?
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user     User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("notifications")
}
